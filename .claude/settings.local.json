{
  "permissions": {
    "allow": [
      "mcp__laravel-boost__application-info",
      "mcp__laravel-boost__database-schema",
      "mcp__laravel-boost__list-routes",
      "mcp__laravel-boost__search-docs",
      "Bash(php artisan install:broadcasting:*)",
      "Bash(composer require:*)",
      "Bash(php artisan vendor:publish:*)",
      "Bash(npm install:*)",
      "Bash(php artisan make:model:*)",
      "Bash(php artisan migrate:*)",
      "Bash(php artisan make:event:*)",
      "Bash(php artisan make:controller:*)",
      "Bash(php artisan make:request:*)",
      "Bash(php artisan make:policy:*)",
      "Bash(curl:*)",
      "Bash(php artisan make:test:*)",
      "Bash(php artisan test:*)",
      "Bash(npm run build:*)",
      "Bash(vendor/bin/pint:*)",
      "Bash(php artisan make:command:*)",
      "mcp__herd__secure_or_unsecure_site",
      "mcp__laravel-boost__last-error",
